# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- LLM (OpenAI-compatible endpoint, e.g. self-hosted on a VPS) ----
LLM_BASE_URL=https://your-llm-host/v1
LLM_API_KEY=your-llm-api-key
LLM_MODEL=your-model-name

# ---- Cron / job auth (shared secret for /api/crawl/* routes) ----
CRON_SECRET=change-me-to-a-long-random-string

# ---- API-Football fallback (optional — only used when Playwright fails) ----
API_FOOTBALL_KEY=

# ---- Used by scripts/ticker.ts & scripts/crawl-bootstrap.ts ----
APP_BASE_URL=http://localhost:3000
