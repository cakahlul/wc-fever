# ---- Supabase ----
# Project URL + API keys: Supabase dashboard → top-bar "Connect" button, or
# Project Settings → API Keys. New projects use the new key format:
#   publishable key  sb_publishable_...  (browser-safe, RLS applies)
#   secret key       sb_secret_...       (server-only, bypasses RLS)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...

# Legacy JWT keys (older projects) still work as fallbacks — set these instead
# if your project predates the new API keys (deprecated end of 2026):
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-legacy-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-legacy-service-role-key

# ---- LLM (OpenAI-compatible endpoint, e.g. self-hosted on a VPS) ----
LLM_BASE_URL=https://your-llm-host/v1
LLM_API_KEY=your-llm-api-key
LLM_MODEL=your-model-name

# ---- Cron / job auth (shared secret for /api/crawl/* routes) ----
CRON_SECRET=change-me-to-a-long-random-string

# ---- API-Football fallback (optional — only used when Playwright fails) ----
API_FOOTBALL_KEY=

# ---- Used by scripts/ticker.ts & scripts/crawl-bootstrap.ts ----
APP_BASE_URL=http://localhost:3000
